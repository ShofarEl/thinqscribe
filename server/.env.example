# Server Configuration
PORT=5000
NODE_ENV=development

# MongoDB Connection String
# For local MongoDB: mongodb://localhost:27017/thinqscribe
# For MongoDB Atlas: mongodb+srv://username:password@cluster-name.mongodb.net/thinqscribe
MONGODB_URI=mongodb+srv://username:password@cluster-name.mongodb.net/thinqscribe

# JWT Secret Key (use a strong, random string - minimum 32 characters)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-minimum-32-characters-long

# CORS Allowed Origins (comma-separated)
# Include all domains where your frontend is deployed
ALLOWED_ORIGINS=https://theskribe.com,https://www.theskribe.com,https://api.theskribe.com,https://thinqscribe.com,https://www.thinqscribe.com,https://thinqscribe-4mly.vercel.app,http://localhost:3000,http://localhost:5173

# Email Service (for future password reset functionality)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-specific-password

# API Keys (for future integrations)
# OPENAI_API_KEY=sk-your-openai-key
# WHATSAPP_API_KEY=your-whatsapp-api-key
